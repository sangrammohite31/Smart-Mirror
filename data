$check = Get-ItemProperty `
HKLM:\Software\Microsoft\Windows\CurrentVersion\Uninstall\*, `
HKLM:\Software\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall\* |
Where-Object { $_.DisplayName -match "Desktop Central|Endpoint Central|UEMS|ManageEngine" }

if ($check) {
    Write-Output "Desktop Central is INSTALLED"
} else {
    Write-Output "Desktop Central is NOT installed"
}


if (
    -not (Get-Service | Where-Object { $_.Name -match "DesktopCentral|UEMS|ManageEngine" }) -and
    -not (Get-ItemProperty HKLM:\Software\Microsoft\Windows\CurrentVersion\Uninstall\*, HKLM:\Software\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall\* | Where-Object { $_.DisplayName -match "Desktop Central|Endpoint Central|UEMS|ManageEngine" })
) {
    "Desktop Central is completely REMOVED ✅"
} else {
    "Desktop Central remnants still exist ⚠️"
}


Get-ItemProperty HKLM:\Software\*\Uninstall\*,HKLM:\Software\WOW6432Node\*\Uninstall\* |
? {$_.DisplayName -match "Desktop Central|Endpoint Central|UEMS|ManageEngine"} |
% { Start-Process "cmd.exe" "/c $($_.UninstallString -replace '/I','/X') /quiet" -Wait }
